{
    "lsp": {
        "basedpyright": {
            "settings": {
                "python": {
                    // "pythonPath": ".pixi/envs/default/bin/python",
                    // "venvPath": ".pixi/envs",
                    "analysis": {
                        "typeCheckingMode": "strict"
                    }
                }
            }
        },
        "ruff": {
            "initialization_options": {
                "settings": {
                    "lineLength": 88,
                    "lint": {
                        "extendSelect": ["I"]
                    }
                }
            }
        }
    },
    "terminal": {
        "detect_venv": {
            "on": {
                "directories": [
                    ".env",
                    "env",
                    ".venv",
                    "venv",
                    ".pixi/envs/default"
                ],
                "activate_script": "default"
            }
        }
    },
    "languages": {
        "Python": {
            "language_servers": ["ruff", "ty", "basedpyright"],
            "format_on_save": "on",
            "code_actions_on_format": {
                "source.organizeImports.ruff": true,
                "source.fixAll.ruff": false
            }
        }
    }
}
